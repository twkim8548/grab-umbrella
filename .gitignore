# --- Go ---
server/bin/
*.exe
*.test
*.out

# --- env / secrets ---
.env
.env.local
*.local

# --- 내부 전용 노트 (남은 작업·운영 메모 등, git 업로드 안 함) ---
*.local.md
docs/internal/

# --- Node / Expo ---
node_modules/
app/.expo/
app/dist/
app/web-build/
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# --- OMC runtime artifacts ---
.omc/

# --- 기상청 가이드 (공개문서, 참조용 바이너리. 출처는 docs/kma-guide/README.md) ---
docs/kma-guide/*.docx
docs/kma-guide/*.xlsx
docs/kma-guide/*.hwp
docs/kma-guide/*.pdf

