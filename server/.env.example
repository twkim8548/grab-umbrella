# --- Server ---
PORT=8080

# --- Database (Supabase 또는 Neon Postgres) ---
# 예: postgres://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=

# --- 기상청 단기예보 조회서비스 ---
# 활용신청 1회로 단기/초단기예보/실황 4개 기능 전부 열림 (자동승인)
# https://www.data.go.kr  → VilageFcstInfoService_2.0
KMA_SERVICE_KEY=
KMA_BASE_URL=http://apis.data.go.kr/1360000/VilageFcstInfoService_2.0

# --- Expo Push ---
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send

# --- Cron (cmd/cron 에서 사용) ---
# 출발 몇 분 전에 푸시할지 (spec §5: 출발 30분 전)
PUSH_LEAD_MINUTES=30
